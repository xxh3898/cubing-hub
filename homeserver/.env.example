# Docker Hub image tag. Use a commit SHA based tag, not latest.
IMAGE_TAG=sha-abcdef1
DOCKERHUB_NAMESPACE=xxh3898

# Runtime data paths on the Mac mini.
POST_IMAGES_HOST_DIR=/Users/chiho/cubing-hub-data/post-images

# MySQL. Replace the values in homeserver/.env on the Mac mini.
DB_NAME=cubing_hub
DB_USERNAME=cubing_hub
DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me

# Spring profile and security.
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
JWT_SECRET=change-me
JWT_EXPIRATION=1800000
JWT_REFRESH_EXPIRATION=604800000
AUTH_REFRESH_COOKIE_SECURE=true
CORS_ALLOWED_ORIGINS=https://cubing-hub.com,https://www.cubing-hub.com

# Local post image storage.
POST_IMAGES_KEY_PREFIX=community/posts
POST_IMAGES_PUBLIC_BASE_URL=https://api.cubing-hub.com/uploads

# SMTP remains an external service. Keep real values only in homeserver/.env.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_STARTTLS_ENABLE=true
SMTP_FROM_ADDRESS=

# Discord webhook remains an external service. Keep the real URL only in homeserver/.env.
FEEDBACK_DISCORD_WEBHOOK_URL=

# Redis ranking rebuild is disabled by default on home-server boot.
RANKING_REDIS_REBUILD_MODE=disabled

# Actuator and monitoring profile.
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,prometheus
MONITORING_PROMETHEUS_PERMIT_ALL=false
GRAFANA_ADMIN_PASSWORD=change-me
